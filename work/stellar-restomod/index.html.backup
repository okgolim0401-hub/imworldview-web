<!DOCTYPE html>
<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;500;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link rel="stylesheet" href="style.css"/>
<script id="tailwind-config">
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        "colors": {
                "secondary-container": "#474746",
                "outline-variant": "#444748",
                "surface-container-highest": "#353535",
                "primary-fixed": "#e2e2e2",
                "on-tertiary-container": "#636565",
                "tertiary-container": "#e2e2e2",
                "on-secondary-fixed": "#1c1b1b",
                "primary-fixed-dim": "#c6c6c7",
                "on-surface-variant": "#c4c7c8",
                "on-primary-fixed-variant": "#454747",
                "surface-dim": "#131313",
                "on-primary": "#2f3131",
                "error-container": "#93000a",
                "background": "#131313",
                "surface": "#131313",
                "surface-container": "#1f1f1f",
                "primary": "#ffffff",
                "on-tertiary-fixed-variant": "#454747",
                "surface-variant": "#353535",
                "secondary-fixed-dim": "#c8c6c5",
                "inverse-on-surface": "#303030",
                "on-tertiary-fixed": "#1a1c1c",
                "inverse-primary": "#5d5f5f",
                "secondary-fixed": "#e5e2e1",
                "on-error-container": "#ffdad6",
                "tertiary-fixed-dim": "#c6c6c7",
                "on-surface": "#e2e2e2",
                "surface-container-low": "#1b1b1b",
                "surface-container-lowest": "#0e0e0e",
                "outline": "#8e9192",
                "on-primary-fixed": "#1a1c1c",
                "on-primary-container": "#636565",
                "on-secondary-container": "#b7b5b4",
                "on-error": "#690005",
                "on-background": "#e2e2e2",
                "secondary": "#c8c6c5",
                "on-secondary-fixed-variant": "#474746",
                "tertiary-fixed": "#e2e2e2",
                "tertiary": "#ffffff",
                "surface-bright": "#393939",
                "primary-container": "#e2e2e2",
                "error": "#ffb4ab",
                "on-tertiary": "#2f3131",
                "on-secondary": "#313030",
                "surface-container-high": "#2a2a2a",
                "inverse-surface": "#e2e2e2",
                "surface-tint": "#c6c6c7"
        },
        "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
        },
        "spacing": {
                "margin": "48px",
                "gutter": "24px",
                "container-max": "1440px",
                "unit": "4px",
                "8": "32px",
                "16": "64px",
                "24": "96px",
                "32": "128px"
        },
        "fontFamily": {
                "label-caps": ["Inter"],
                "body-base": ["Inter"],
                "headline-md": ["Inter"],
                "display-lg": ["Space Grotesk"],
                "mono-data": ["Inter"],
                "label-mono": ["Space Grotesk"],
                "d-din": ["D-DIN", "sans-serif"]
        },
        "fontSize": {
                "label-caps": [
                        "12px",
                        {
                                "lineHeight": "1",
                                "letterSpacing": "0.15em",
                                "fontWeight": "700"
                        }
                ],
                "body-base": [
                        "16px",
                        {
                                "lineHeight": "1.6",
                                "letterSpacing": "0em",
                                "fontWeight": "400"
                        }
                ],
                "headline-md": [
                        "32px",
                        {
                                "lineHeight": "1.2",
                                "letterSpacing": "-0.02em",
                                "fontWeight": "600"
                        }
                ],
                "display-lg": [
                        "72px",
                        {
                                "lineHeight": "1.1",
                                "letterSpacing": "-0.04em",
                                "fontWeight": "700"
                        }
                ],
                "mono-data": [
                        "14px",
                        {
                                "lineHeight": "1.4",
                                "letterSpacing": "-0.01em",
                                "fontWeight": "500"
                        }
                ]
        }
},
    },
  }
</script>
<!-- Removed duplicate scripts from head -->
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        body {
            background-color: #000000;
            color: #e2e2e2;
            overflow-x: hidden;
        }
        .grid-line-v {
            width: 0.5px;
            background-color: rgba(255, 255, 255, 0.15);
            height: 100%;
            position: absolute;
            transform-origin: top;
            transform: scaleY(0);
            transition: transform 3s cubic-bezier(0.2, 0.9, 0.3, 1);
        }
        .grid-line-h {
            height: 0.5px;
            background-color: rgba(255, 255, 255, 0.15);
            width: 100%;
            position: absolute;
            transform-origin: left;
            transform: scaleX(0);
            transition: transform 3s cubic-bezier(0.2, 0.9, 0.3, 1);
        }
        .grid-line-v.active, .grid-line-h.active {
            transform: scale(1);
        }
        
        /* Thin line animation */
        .expand-line {
            transform-origin: left;
            transform: scaleX(0);
            transition: transform 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .expand-line.expanded {
            transform: scaleX(1);
        }
        
        .button-ghost {
            border: 1px solid white;
            transition: all 0.2s ease;
        }
        .button-ghost:hover {
            background-color: white;
            color: #000000;
        }

        /* Diagram Box Drawing Animation */
        .diagram-seq-box.is-drawn .border-draw-top,
        .diagram-seq-box.is-drawn .border-draw-bottom {
            width: calc(100% - 32px);
        }
        .diagram-seq-box.is-drawn .border-draw-right,
        .diagram-seq-box.is-drawn .border-draw-left {
            height: calc(100% - 32px);
        }

        /* Flowing Guide Line Animation */
        @keyframes flowing-line {
            0% { background-position: 0% -100%; }
            100% { background-position: 0% 100%; }
        }
        .line-flowing {
            background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.8), transparent);
            background-size: 100% 200%;
            animation: flowing-line 2s linear infinite;
        }
        
        /* Transition Dots & Lines (Waterfall Cascade) */
        .transition-dot {
            width: 3px;
            height: 3px;
            background-color: white;
            border-radius: 50%;
            opacity: 0;
            transform: scale(0);
            transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;
            box-shadow: 0 0 4px rgba(255, 255, 255, 0.6);
        }
        .transition-dot.active {
            opacity: 1;
            transform: scale(1);
            animation: dot-pulse 2s infinite ease-in-out;
        }
        .transition-line {
            width: 1px;
            height: 0px;
            background: linear-gradient(to bottom, rgba(255, 255, 255, 0.6), transparent);
            opacity: 0;
            margin-top: 16px; /* 16px gap to match diagram's detached aesthetic */
            transition: height 1.8s cubic-bezier(0.2, 0.9, 0.3, 1), opacity 0.8s ease;
            pointer-events: none;
        }
        .transition-line.active {
            opacity: 1;
            height: 420px;
        }
        
        /* Corner Dots Animation */
        @keyframes dot-pulse {
            0%, 100% { opacity: 0.3; transform: scale(1); box-shadow: 0 0 2px rgba(255,255,255,0.2); }
            50% { opacity: 1; transform: scale(1.5); box-shadow: 0 0 8px rgba(255,255,255,1); }
        }
        .corner-dot {
            position: absolute;
            width: 2px;
            height: 2px;
            background-color: white;
            z-index: 30;
            border-radius: 50%;
            animation: dot-pulse 2s infinite ease-in-out;
        }
        .corner-dot.tl { top: 0; left: 0; animation-delay: 0.1s; }
        .corner-dot.tr { top: 0; right: 0; animation-delay: 0.6s; }
        .corner-dot.br { bottom: 0; right: 0; animation-delay: 0.3s; }
        .corner-dot.bl { bottom: 0; left: 0; animation-delay: 0.8s; }

        /* --- Simple Boot Intro --- */
        #boot-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background: #000;
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 1s ease;
        }
        
        .pixel-sequence {
            display: flex;
            gap: 1.5rem;
        }
        
        .pixel-container {
            position: relative;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .pixel-svg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: visible;
        }
        
        .pixel-rect {
            fill: none;
            stroke: rgba(255, 255, 255, 0.9);
            stroke-width: 1.5;
            stroke-dasharray: 160;
            stroke-dashoffset: 160;
            transition: stroke-dashoffset 0.6s ease;
            filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.8)) drop-shadow(0 0 12px rgba(255, 255, 255, 0.4));
        }
        
        .pixel-container.drawn .pixel-rect {
            stroke-dashoffset: 0;
        }

        @keyframes blink-twice {
            0%, 20%, 40%, 100% { opacity: 1; }
            10%, 30% { opacity: 0; }
        }
        
        .pixel-container.blink {
            animation: blink-twice 0.5s ease-in-out forwards;
        }
        
        .pixel-container.blink .pixel-rect {
            fill: rgba(255, 255, 255, 1);
            stroke: none;
            filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.9));
        }

        /* --- Refik Anadol Tech SVG Artwork Animations --- */
        .diagram-artwork-wrap {
            opacity: 0;
            transform: scale(0.96);
            transition: opacity 1.5s cubic-bezier(0.16, 1, 0.3, 1), transform 1.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .diagram-seq-box.is-drawn .diagram-artwork-wrap {
            opacity: 0.85;
            transform: scale(1);
        }

        /* 1. Box 1 Wedge drawing animation */
        .wedge-path {
            stroke-dasharray: 600;
            stroke-dashoffset: 600;
            transition: stroke-dashoffset 2.0s cubic-bezier(0.22, 1, 0.36, 1);
            transition-delay: 500ms;
        }
        .diagram-seq-box.is-drawn .wedge-path {
            stroke-dashoffset: 0;
        }
        .wedge-path-shadow {
            stroke-dasharray: 600;
            stroke-dashoffset: 600;
            transition: stroke-dashoffset 2.0s cubic-bezier(0.22, 1, 0.36, 1);
            transition-delay: 500ms;
        }
        .diagram-seq-box.is-drawn .wedge-path-shadow {
            stroke-dashoffset: 0;
        }

        /* 2. Box 2 Laser scanner & wave morphing animations */
        @keyframes laserScan {
            0% { transform: translateY(0); opacity: 0.2; }
            50% { opacity: 0.8; }
            100% { transform: translateY(240px); opacity: 0.2; }
        }
        .scanner-bar {
            transform-origin: center;
            animation: laserScan 4s ease-in-out infinite;
        }

        @keyframes waveOscillate {
            0%, 100% { transform: translateY(0) scaleY(1); }
            50% { transform: translateY(-6px) scaleY(1.06); }
        }
        .contour-wave {
            transform-origin: center;
            animation: waveOscillate 6s ease-in-out infinite;
        }
        .contour-wave.wave-2 {
            animation-delay: -2s;
            animation-duration: 5s;
        }
        .contour-wave.wave-3 {
            animation-delay: -4s;
            animation-duration: 7s;
        }

        @keyframes nodeSparkle {
            0%, 100% { opacity: 0.2; r: 1.2; }
            50% { opacity: 1; r: 2.2; filter: drop-shadow(0 0 3px rgba(255,255,255,0.8)); }
        }
        .sparkle-dot {
            animation: nodeSparkle 3s infinite ease-in-out;
        }
        .sparkle-dot.s-2 { animation-delay: 0.7s; animation-duration: 2.5s; }
        .sparkle-dot.s-3 { animation-delay: 1.4s; animation-duration: 3.5s; }
        .sparkle-dot.s-4 { animation-delay: 2.1s; animation-duration: 2.8s; }

        /* 3. Box 3 Circular radar sweep & satellite orbits */
        @keyframes radarSweep {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .radar-sweep {
            transform-origin: 200px 200px;
            animation: radarSweep 8s linear infinite;
        }

        @keyframes orbitCW {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        @keyframes orbitCCW {
            0% { transform: rotate(360deg); }
            100% { transform: rotate(0deg); }
        }

        .satellite-group {
            transform-origin: 200px 200px;
        }
        .satellite-group.inner-rot {
            animation: orbitCW 6s linear infinite;
        }
        .satellite-group.mid-rot {
            animation: orbitCCW 10s linear infinite;
        }
        .satellite-group.outer-rot {
            animation: orbitCW 15s linear infinite;
        }

        .sat-glow {
            filter: drop-shadow(0 0 4px rgba(255,255,255,0.9));
        }

        @keyframes textFlicker {
            0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 0.3; }
            20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 1; filter: drop-shadow(0 0 2px rgba(255,255,255,0.5)); }
        }
        .flicker-text {
            animation: textFlicker 6s infinite;
        }

    </style>
</head>
<body class="font-body-base text-body-base selection:bg-primary selection:text-background bg-black">
    <!-- Boot Loader Intro -->
    <div id="boot-loader">
        <div class="pixel-sequence">
            <div class="pixel-container" id="c1">
                <svg class="pixel-svg" viewBox="0 0 40 40">
                    <rect class="pixel-rect" x="1" y="1" width="38" height="38" />
                </svg>
            </div>
            <div class="pixel-container" id="c2">
                <svg class="pixel-svg" viewBox="0 0 40 40">
                    <rect class="pixel-rect" x="1" y="1" width="38" height="38" />
                </svg>
            </div>
            <div class="pixel-container" id="c3">
                <svg class="pixel-svg" viewBox="0 0 40 40">
                    <rect class="pixel-rect" x="1" y="1" width="38" height="38" />
                </svg>
            </div>
            <div class="pixel-container" id="c4">
                <svg class="pixel-svg" viewBox="0 0 40 40">
                    <rect class="pixel-rect" x="1" y="1" width="38" height="38" />
                </svg>
            </div>
        </div>
    </div>

<div class="w-full relative bg-black">
<!-- Global Layout Lines -->
<div class="absolute inset-0 pointer-events-none z-50 overflow-hidden">
</div>
<!-- TopNavBar -->
<nav class="sticky top-0 w-full z-[60] bg-black/20 backdrop-blur-xl border-b border-white/10 h-16 flex justify-between items-center px-margin">
<div class="font-label-mono text-[12px] font-bold tracking-[0.2em] text-primary flex items-center">
<img alt="IMWV Logo" class="h-6 w-auto object-contain brightness-0 invert" src="IMWV_logo.png"/>
</div>
<div class="hidden md:flex items-center gap-8 ml-auto">
<a class="text-on-surface-variant font-label-mono text-[12px] uppercase tracking-wider hover:text-primary transition-colors duration-200" href="#">Work</a>
<a class="text-on-surface-variant font-label-mono text-[12px] uppercase tracking-wider hover:text-primary transition-colors duration-200" href="#">About</a>
<a class="text-on-surface-variant font-label-mono text-[12px] uppercase tracking-wider hover:text-primary transition-colors duration-200" href="#">Contact</a>
<a aria-label="Instagram" class="text-on-surface-variant hover:text-primary transition-colors duration-200 ml-4" href="#">
<svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><rect height="20" rx="5" ry="5" width="20" x="2" y="2"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
</a>
</div>
</nav>
<main class="relative">
<!-- Hero Section -->
<section class="min-h-screen relative flex flex-col justify-end pb-32 px-margin overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img alt="STELLAR Hero Image" class="w-full h-full object-cover object-[center_80%]" src="4.jpg"/>
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
    </div>
    <div class="relative z-10 flex flex-col gap-6">
        <span class="font-label-mono text-[13px] text-primary uppercase tracking-[0.5em] opacity-70 scramble-text ml-[6px]" data-original="Hyundai STELLAR Restomod Design competition" data-reveal-delay="0">Hyundai STELLAR Restomod Design competition</span>
        <h1 class="font-display-lg text-primary uppercase tracking-[-0.04em] font-medium text-[64px] md:text-[96px] leading-[0.9] scramble-text break-keep whitespace-nowrap" data-original="STELLAR, STILL HERE" data-reveal-delay="300">STELLAR, STILL HERE</h1>
        <div class="expand-line w-full h-[1px] bg-white/20 mt-8 mb-4"></div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="flex flex-col gap-1">
                <span class="font-label-mono text-[13px] text-outline uppercase tracking-[0.2em] scramble-text" data-reveal-delay="2800">DATE</span>
                <span class="font-label-mono text-[20px] text-primary uppercase font-bold tracking-tight scramble-text" data-original="2025" data-reveal-delay="2800">2025</span>
            </div>
            <div class="flex flex-col gap-1">
                <span class="font-label-mono text-[13px] text-outline uppercase tracking-[0.2em] scramble-text" data-reveal-delay="3000">INDUSTRY</span>
                <span class="font-label-mono text-[20px] text-primary uppercase font-bold tracking-tight scramble-text" data-original="MOBILITY" data-reveal-delay="3000">MOBILITY</span>
            </div>
            <div class="flex flex-col gap-1">
                <span class="font-label-mono text-[13px] text-outline uppercase tracking-[0.2em] scramble-text" data-reveal-delay="3200">HOST</span>
                <span class="font-label-mono text-[20px] text-primary uppercase font-bold tracking-tight scramble-text" data-original="HYUNDAI MOTOR STUDIO&#10;EREVO" data-reveal-delay="3200">HYUNDAI MOTOR STUDIO<br/>EREVO</span>
            </div>
        </div>
    </div>
</section>
<!-- Concept Section -->
<section class="min-h-screen py-32 px-margin flex flex-col justify-center relative bg-black">
<div class="flex flex-col mb-24 md:mb-48">
<span class="font-label-mono text-[12px] text-primary uppercase tracking-[0.3em] opacity-60 scramble-text" data-original="OVERVIEW / 01">OVERVIEW / 01</span>
<div class="flex flex-col gap-12 mt-[50px]">
<h2 class="font-headline-md text-[32px] md:text-[56px] text-primary tracking-tight font-light font-label-mono leading-[1.15] uppercase text-left scramble-text" data-scramble-type="random" data-original="CONNECTING&#10;PAST, PRESENT, AND FUTURE.">CONNECTING<br/>PAST, PRESENT, AND FUTURE.</h2>
<div class="flex flex-col gap-10 max-w-[900px]">
<p class="font-body-base text-[16px] md:text-[18px] text-on-surface leading-[2.2] font-normal text-left scramble-text">
스텔라는 포니와 함께 대한민국 자동차 모델의 시작점이자 시대를 상징하는 유산으로, 단순한 과거의 기억이 아닌, 여전히 살아 숨 쉬는 영감의 원천입니다. 우리는 그 본질을 존중하면서도 현대적 언어로 다시 정의하여, 단순한 복원이 아닌 새로운 디자인 언어와 경험으로 재해석한 스텔라를 제안합니다.
</p>
<p id="english-text-trigger" class="font-body-base text-[15px] md:text-[17px] text-on-surface-variant leading-[2.2] font-normal tracking-wide text-left opacity-40 scramble-text">
Stellar, alongside Pony, stands as a pioneering archetype of Korean automotive history and a heritage symbolizing an era. Far from being a mere relic of the past, it remains a living source of inspiration. Respecting its core essence while redefining it through a contemporary lens, we propose a reincarnated Stellar—reinterpreted not as a simple restoration, but as an entirely new design language and experience.
</p>
</div>
</div>
</div>
<!-- Diagram -->
<div class="w-full relative mt-0" id="diagram-container">
<div class="grid grid-cols-1 md:grid-cols-3 gap-0 relative z-10 w-full" id="diagram-grid">

<!-- Box 1 -->
<div class="diagram-seq-box aspect-square flex flex-col justify-between p-6 md:p-10 bg-transparent relative overflow-hidden transition-opacity duration-300">
<!-- Corner Dots -->
<div class="corner-dot tl"></div>
<div class="corner-dot tr"></div>
<div class="corner-dot br"></div>
<div class="corner-dot bl"></div>
<!-- Animated Borders -->
<div class="border-draw-top absolute top-0 left-[16px] h-[1px] bg-white/40 w-0 transition-all duration-300 ease-linear z-20"></div>
<div class="border-draw-right absolute top-[16px] right-0 w-[1px] bg-white/40 h-0 transition-all duration-300 delay-[300ms] ease-linear z-20"></div>
<div class="border-draw-bottom absolute bottom-0 right-[16px] h-[1px] bg-white/40 w-0 transition-all duration-300 delay-[600ms] ease-linear z-20"></div>
<div class="border-draw-left absolute bottom-[16px] left-0 w-[1px] bg-white/40 h-0 transition-all duration-300 delay-[900ms] ease-linear z-20"></div>
<!-- Refik Anadol Style Tech SVG Artwork (Box 1: Wedge DNA) -->
<div class="absolute inset-0 z-0 pointer-events-none opacity-0 scale-95 transition-all duration-1000 ease-out diagram-artwork-wrap">
<svg class="w-full h-full text-white" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
    <defs>
        <pattern id="grid-p1" width="25" height="25" patternUnits="userSpaceOnUse">
            <path d="M 25 0 L 0 0 0 25" fill="none" stroke="rgba(255, 255, 255, 0.05)" stroke-width="0.5" />
        </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid-p1)" />
    <g stroke="rgba(255, 255, 255, 0.12)" stroke-width="0.8" fill="none">
        <line x1="40" y1="360" x2="360" y2="360" />
        <line x1="40" y1="40" x2="40" y2="360" />
        <line x1="40" y1="360" x2="360" y2="40" stroke-dasharray="4, 4" stroke="rgba(255,255,255,0.06)" />
    </g>
