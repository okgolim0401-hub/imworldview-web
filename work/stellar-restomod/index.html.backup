        <animateMotion dur="3.5s" begin="1.5s" repeatCount="indefinite" path="M 40 360 L 160 200 L 260 280 L 360 40" />
    </circle>
    <g fill="rgba(255, 255, 255, 0.3)" font-family="Space Grotesk, Courier" font-size="8">
