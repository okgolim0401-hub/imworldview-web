<div class="absolute bottom-6 right-6 bg-black/70 backdrop-blur-md px-4 py-2 border border-white/15 cursor-pointer hover:bg-white/20 hover:border-white/40 transition-all duration-300 z-20 group/btn" onclick="openLightbox('2.jpg', 'STELLAR_SIDE_VIEW_01')">
